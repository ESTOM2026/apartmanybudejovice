---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import B2BSection from '../components/B2BSection.astro';
import { useTranslations } from '../i18n/utils';
import { getRoute } from '../i18n/routes';

const lang = 'cs';
const t = useTranslations(lang);
---
<BaseLayout
  pageKey="home"
  title="Lets Go Apartment — rodinný apartmán Č. Budějovice"
  description="Rodinný apartmán Lets Go v Českých Budějovicích — 70 m², plně vybavená kuchyň, parkování zdarma, vhodné pro rodiny i firemní pobyty. Cena od 1 200 Kč/noc."
>
  <Hero />
  <Features />
  <B2BSection />

  <section class="py-20 md:py-24">
    <div class="container-narrow text-center">
      <h2 class="text-3xl md:text-4xl font-medium mb-5">{t('contact.title')}</h2>
      <p class="text-lg text-[var(--color-ink-soft)] max-w-xl mx-auto mb-8">{t('contact.lead')}</p>
      <a href={getRoute('contact', lang)} class="btn-primary">
        {t('cta.inquire')}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
    </div>
  </section>
</BaseLayout>
