---
import { getLangFromUrl } from '../i18n/utils';
import { getRoute, type PageKey } from '../i18n/routes';
import { languages, type Lang } from '../i18n/ui';

interface Props {
  pageKey: PageKey;
}

const { pageKey } = Astro.props;
const currentLang = getLangFromUrl(Astro.url);
const langs = Object.keys(languages) as Lang[];
---
<div class="flex items-center gap-1">
  {langs.map((l) => {
    const code = l === 'cs' ? 'cz' : l === 'en' ? 'gb' : 'de';
    const label = l === 'cs' ? 'Čeština' : l === 'en' ? 'English' : 'Deutsch';
    return (
      <a
        href={getRoute(pageKey, l)}
        hreflang={l === 'cs' ? 'cs-CZ' : l === 'en' ? 'en' : 'de-DE'}
        class:list={[
          'transition-opacity',
          l === currentLang ? 'opacity-100' : 'opacity-30 hover:opacity-60'
        ]}
        aria-current={l === currentLang ? 'true' : undefined}
        title={label}
      >
        <img
          src={`https://hatscripts.github.io/circle-flags/flags/${code}.svg`}
          width="24"
          height="24"
          alt={label}
          loading="eager"
        />
      </a>
    );
  })}
</div>
