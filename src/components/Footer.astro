---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { getRoute } from '../i18n/routes';
import LegoBrick from './LegoBrick.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const year = new Date().getFullYear();
---
<footer class="mt-10 border-t border-[var(--color-line)] bg-white">
  <div class="container-wide py-8 grid gap-8 md:grid-cols-3">
    <div>
      <div class="flex items-center gap-2.5 font-display text-lg mb-2">
        <LegoBrick size={32} color="var(--color-lego-red)" />
        <span class="font-semibold">Lets Go Apartment</span>
      </div>
      <p class="text-sm text-[var(--color-ink-soft)] max-w-xs">{t('footer.tagline')}</p>
    </div>

    <div>
      <h3 class="text-sm uppercase tracking-wider text-[var(--color-muted)] mb-3 font-sans font-semibold">{t('footer.links')}</h3>
      <ul class="space-y-2 text-sm">
        <li><a href={getRoute('apartment', lang)} class="hover:text-[var(--color-cta)]">{t('nav.apartment')}</a></li>
        <li><a href={getRoute('business', lang)} class="hover:text-[var(--color-cta)]">{t('nav.business')}</a></li>
        <li><a href={getRoute('about', lang)} class="hover:text-[var(--color-cta)]">{t('nav.about')}</a></li>
        <li><a href={getRoute('contact', lang)} class="hover:text-[var(--color-cta)]">{t('nav.contact')}</a></li>
      </ul>
    </div>

    <div>
      <h3 class="text-sm uppercase tracking-wider text-[var(--color-muted)] mb-3 font-sans font-semibold">{t('footer.contact')}</h3>
      <ul class="space-y-2 text-sm">
        <li><a href="mailto:info@estom.cz" class="hover:text-[var(--color-cta)]">info@estom.cz</a></li>
        <li><a href="tel:+420777925594" class="hover:text-[var(--color-cta)]">+420 777 925 594</a></li>
        <li class="text-[var(--color-muted)]">I. Olbrachta 910/34, České Budějovice</li>
      </ul>
    </div>
  </div>

  <div class="border-t border-[var(--color-line)]">
    <div class="container-wide pt-8 pb-4 space-y-3 text-xs text-[var(--color-muted)] leading-relaxed">
      {lang === 'cs' && (
        <>
          <h2 class="text-xs font-semibold text-[var(--color-ink-soft)] uppercase tracking-wider">Levné ubytování v Českých Budějovicích a jižních Čechách — nejlepší poměr ceny a kvality</h2>
          <p>
            Hledáte levné ubytování v&nbsp;Českých Budějovicích s&nbsp;nejlepším poměrem ceny a&nbsp;kvality? <strong class="font-medium text-[var(--color-ink-soft)]">Lets Go Family Apartment</strong> nabízí prostorný dvoupokojový apartmán (2&nbsp;+&nbsp;1) o&nbsp;rozloze 70&nbsp;m² v&nbsp;klidné čtvrti — jen 7&nbsp;minut autem od historického náměstí. Pronájem je ideální na krátkodobý i&nbsp;střednědobý pobyt: víkendová dovolená, pracovní cesta do jižních Čech, nebo několikatýdenní pobyt pro rodinu s&nbsp;dětmi.
          </p>
          <p>
            <strong class="font-medium text-[var(--color-ink-soft)]">Plně vybavený apartmán — nastěhujte se rovnou:</strong> Americká lednice, myčka nádobí, pračka se sušičkou, rychlá Wi‑Fi, dvě televize, herní konzole Xbox, hračky pro děti a&nbsp;unikátní sbírka LEGO modelů. Koupelna se sprchovým koutem i&nbsp;vanou. Ubytování v&nbsp;Jihočeském kraji, kde se hosté cítí jako doma — ne jako v&nbsp;hotelu.
          </p>
          <p>
            <strong class="font-medium text-[var(--color-ink-soft)]">Střednědobý a dlouhodobý pronájem pro firmy:</strong> Potřebujete ubytovat zaměstnance, stážisty nebo montéry v&nbsp;Českých Budějovicích na týden, měsíc nebo déle? Nabízíme firemní ubytování s&nbsp;fakturací na IČO, s&nbsp;DPH i&nbsp;bez. Střednědobý pronájem v&nbsp;jižních Čechách s&nbsp;flexibilní délkou pobytu a&nbsp;cenou od 950&nbsp;Kč za noc. Pro větší týmy zajistíme více apartmánů v&nbsp;lokalitě.
          </p>
          <p>
            <strong class="font-medium text-[var(--color-ink-soft)]">Dostupnost a lokalita:</strong> Apartmán se nachází na adrese I.&nbsp;Olbrachta&nbsp;910/34, České Budějovice. Autobusová zastávka 100&nbsp;m, vlakové a&nbsp;autobusové nádraží 2&nbsp;km, dálnice D3 v&nbsp;dosahu — snadno dostupné z&nbsp;Prahy, Brna i&nbsp;Plzně. Parkování zdarma. Park s&nbsp;rybníkem za rohem.
          </p>
          <p>
            <strong class="font-medium text-[var(--color-ink-soft)]">Rezervace bez prostředníků:</strong> Rezervujte přímo — bez provizí portálů jako Airbnb nebo Booking. Napište nám termín a&nbsp;počet osob přes <a href="/kontakt" class="hover:text-[var(--color-ink)] underline underline-offset-2">kontaktní formulář</a> a&nbsp;ozveme se do 24&nbsp;hodin. Cena ubytování v&nbsp;Českých Budějovicích od 1&nbsp;200&nbsp;Kč za noc, při střednědobém pobytu cena dohodou.
          </p>
        </>
      )}
      {lang === 'en' && (
        <>
          <h2 class="text-xs font-semibold text-[var(--color-ink-soft)] uppercase tracking-wider">Affordable apartment rental in České Budějovice, South Bohemia — best value for money</h2>
          <p>
            Looking for affordable accommodation in České Budějovice with the best value for money? <strong class="font-medium text-[var(--color-ink-soft)]">Lets Go Family Apartment</strong> offers a spacious 70&nbsp;m² flat in a quiet neighbourhood — 7 minutes from the historic square. Ideal for short breaks, mid‑term stays, family holidays or business trips to South Bohemia.
          </p>
          <p>
            <strong class="font-medium text-[var(--color-ink-soft)]">Fully equipped — move in straight away:</strong> American fridge, dishwasher, washer &amp; dryer, Wi‑Fi, two TVs, Xbox, toys for children, unique LEGO collection. Shower and bathtub. Guests feel at home, not in a hotel. Free parking, bus stop 100&nbsp;m, train station 2&nbsp;km.
          </p>
          <p>
            <strong class="font-medium text-[var(--color-ink-soft)]">Mid‑term corporate stays:</strong> Need to house employees, interns or contractors in České Budějovice for weeks or months? Company invoicing, with or without VAT. From CZK&nbsp;950/night. Multiple units available. Book directly via our <a href="/en/contact" class="hover:text-[var(--color-ink)] underline underline-offset-2">contact form</a> — no agency fees, reply within 24&nbsp;hours.
          </p>
        </>
      )}
      {lang === 'de' && (
        <>
          <h2 class="text-xs font-semibold text-[var(--color-ink-soft)] uppercase tracking-wider">Günstige Unterkunft in Budweis, Südböhmen — bestes Preis-Leistungs-Verhältnis</h2>
          <p>
            Suchen Sie günstige Unterkunft in České Budějovice (Budweis) mit bestem Preis-Leistungs-Verhältnis? <strong class="font-medium text-[var(--color-ink-soft)]">Lets Go Family Apartment</strong> bietet ein geräumiges 70&nbsp;m²-Apartment in ruhiger Lage — 7 Minuten vom historischen Marktplatz. Ideal für Kurzurlaub, Mittelfristaufenthalt oder Familienurlaub in Südböhmen.
          </p>
          <p>
            <strong class="font-medium text-[var(--color-ink-soft)]">Voll ausgestattet — sofort einzugsbereit:</strong> Amerikanischer Kühlschrank, Geschirrspüler, Waschmaschine &amp; Trockner, WLAN, zwei TVs, Xbox, Kinderspielzeug, einzigartige LEGO‑Sammlung. Dusche und Badewanne. Kostenfreie Parkplätze, Bushaltestelle 100&nbsp;m, Bahnhof 2&nbsp;km.
          </p>
          <p>
            <strong class="font-medium text-[var(--color-ink-soft)]">Mittelfristige Firmenunterkunft:</strong> Mitarbeiter, Praktikanten oder Monteure in Budweis für Wochen oder Monate unterbringen? Firmenrechnung mit oder ohne MwSt. Ab 950&nbsp;CZK/Nacht. Direkt buchen über unser <a href="/de/kontakt" class="hover:text-[var(--color-ink)] underline underline-offset-2">Kontaktformular</a> — keine Vermittlungsgebühren, Antwort innerhalb von 24&nbsp;Stunden.
          </p>
        </>
      )}
    </div>
  </div>

  <div class="border-t border-[var(--color-line)]">
    <div class="container-wide py-5 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-[var(--color-muted)]">
      <span>© {year} Apartmány České Budějovice. {t('footer.rights')}</span>
      <span>{t('about.languages')}</span>
    </div>
  </div>
</footer>
