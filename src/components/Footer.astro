---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { getRoute } from '../i18n/routes';
import LegoBrick from './LegoBrick.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const year = new Date().getFullYear();
---
<footer class="mt-10 border-t border-[var(--color-line)] bg-white">
  <div class="container-wide py-8 grid gap-8 md:grid-cols-3">
    <div>
      <div class="flex items-center gap-2.5 font-display text-lg mb-2">
        <LegoBrick size={32} color="var(--color-lego-red)" />
        <span class="font-semibold">Lets Go Apartment</span>
      </div>
      <p class="text-sm text-[var(--color-ink-soft)] max-w-xs">{t('footer.tagline')}</p>
    </div>

    <div>
      <h3 class="text-sm uppercase tracking-wider text-[var(--color-muted)] mb-3 font-sans font-semibold">{t('footer.links')}</h3>
      <ul class="space-y-2 text-sm">
        <li><a href={getRoute('apartment', lang)} class="hover:text-[var(--color-cta)]">{t('nav.apartment')}</a></li>
        <li><a href={getRoute('business', lang)} class="hover:text-[var(--color-cta)]">{t('nav.business')}</a></li>
        <li><a href={getRoute('about', lang)} class="hover:text-[var(--color-cta)]">{t('nav.about')}</a></li>
        <li><a href={getRoute('contact', lang)} class="hover:text-[var(--color-cta)]">{t('nav.contact')}</a></li>
      </ul>
    </div>

    <div>
      <h3 class="text-sm uppercase tracking-wider text-[var(--color-muted)] mb-3 font-sans font-semibold">{t('footer.contact')}</h3>
      <ul class="space-y-2 text-sm">
        <li><a href="mailto:info@estom.cz" class="hover:text-[var(--color-cta)]">info@estom.cz</a></li>
        <li><a href="tel:+420777925594" class="hover:text-[var(--color-cta)]">+420 777 925 594</a></li>
        <li class="text-[var(--color-muted)]">I. Olbrachta 910/34, České Budějovice</li>
      </ul>
    </div>
  </div>

  <div class="border-t border-[var(--color-line)]">
    <div class="container-wide pt-6 pb-2">
      {lang === 'cs' && (
        <p class="text-xs text-[var(--color-muted)] leading-relaxed max-w-4xl">
          <strong class="font-medium">Lets Go Family Apartment</strong> — apartmán k pronájmu v Českých Budějovicích, I. Olbrachta 910/34. Rodinné ubytování 70 m², 2+1, plně vybavená kuchyň, parkování zdarma, Wi‑Fi. Vhodné pro rodiny s dětmi, dlouhodobé pobyty i firemní ubytování zaměstnanců s fakturou na IČO. Ceny od 1 200 Kč/noc, pro firmy od 950 Kč/noc. Rezervace na <a href="tel:+420777925594" class="hover:text-[var(--color-ink)] underline underline-offset-2">+420 777 925 594</a> nebo <a href="mailto:info@estom.cz" class="hover:text-[var(--color-ink)] underline underline-offset-2">info@estom.cz</a>.
        </p>
      )}
      {lang === 'en' && (
        <p class="text-xs text-[var(--color-muted)] leading-relaxed max-w-4xl">
          <strong class="font-medium">Lets Go Family Apartment</strong> — apartment for rent in České Budějovice, I. Olbrachta 910/34. 70 m², 2 rooms + kitchen, fully equipped, free parking, Wi‑Fi. Ideal for families, long‑term stays and corporate accommodation with company invoicing. From CZK 1,200/night. Book at <a href="tel:+420777925594" class="hover:text-[var(--color-ink)] underline underline-offset-2">+420 777 925 594</a> or <a href="mailto:info@estom.cz" class="hover:text-[var(--color-ink)] underline underline-offset-2">info@estom.cz</a>.
        </p>
      )}
      {lang === 'de' && (
        <p class="text-xs text-[var(--color-muted)] leading-relaxed max-w-4xl">
          <strong class="font-medium">Lets Go Family Apartment</strong> — Apartment zur Miete in Budweis (České Budějovice), I. Olbrachta 910/34. 70 m², 2 Zimmer + Küche, voll ausgestattet, kostenfreie Parkplätze, WLAN. Ideal für Familien, Langzeitaufenthalte und Firmenunterkunft mit Rechnung. Ab 1.200 CZK/Nacht. Kontakt: <a href="tel:+420777925594" class="hover:text-[var(--color-ink)] underline underline-offset-2">+420 777 925 594</a> oder <a href="mailto:info@estom.cz" class="hover:text-[var(--color-ink)] underline underline-offset-2">info@estom.cz</a>.
        </p>
      )}
    </div>
  </div>

  <div class="border-t border-[var(--color-line)]">
    <div class="container-wide py-5 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-[var(--color-muted)]">
      <span>© {year} Apartmány České Budějovice. {t('footer.rights')}</span>
      <span>{t('about.languages')}</span>
    </div>
  </div>
</footer>
