---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { getRoute } from '../i18n/routes';
import type { UIKey } from '../i18n/ui';

interface Props {
  /**
   * 'lego'    — playful: LEGO blue background, yellow accents, stud overlay (default, used on home).
   * 'classic' — sober:   deep-green background, warm-honey accents, no studs (used on /pro-firmy page).
   */
  variant?: 'lego' | 'classic';
}

const { variant = 'lego' } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

type Point = { title: UIKey; text: UIKey };
const points: Point[] = [
  { title: 'b2b.point1.title', text: 'b2b.point1.text' },
  { title: 'b2b.point2.title', text: 'b2b.point2.text' },
  { title: 'b2b.point3.title', text: 'b2b.point3.text' },
  { title: 'b2b.point4.title', text: 'b2b.point4.text' },
];

const isLego = variant === 'lego';
---
{isLego ? (
  <section class="stud-band py-12 md:py-20 text-white relative overflow-hidden" style="background: var(--color-lego-blue);">
    <div class="container-wide relative">
      <div class="grid lg:grid-cols-12 gap-12">
        <div class="lg:col-span-5">
          <span class="inline-block text-sm uppercase tracking-[0.2em] mb-4 font-semibold" style="color: var(--color-lego-yellow);">B2B</span>
          <h2 class="text-4xl md:text-5xl font-medium mb-6 text-white leading-[1.05]">{t('b2b.title')}</h2>
          <p class="text-white/85 text-lg leading-relaxed mb-8">{t('b2b.lead')}</p>
          <a href={getRoute('contact', lang)} class="btn-yellow">
            {t('b2b.cta')}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        </div>

        <ul class="lg:col-span-7 grid sm:grid-cols-2 gap-6">
          {points.map((p, i) => (
            <li class="bg-white/10 backdrop-blur-sm border border-white/20 rounded-xl p-6">
              <div class="w-9 h-9 rounded-full flex items-center justify-center font-display font-semibold text-sm mb-4" style="background: var(--color-lego-yellow); color: var(--color-lego-blue);">
                {i + 1}
              </div>
              <h3 class="text-base font-display font-medium mb-2 text-white">{t(p.title)}</h3>
              <p class="text-sm text-white/80 leading-relaxed">{t(p.text)}</p>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>
) : (
  <section class="py-12 md:py-20 text-white relative overflow-hidden" style="background: var(--color-classic-cta);">
    <div class="absolute inset-0 opacity-[0.06]" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 24px 24px;"></div>

    <div class="container-wide relative">
      <ul class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {points.map((p, i) => (
          <li class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-xl p-6">
            <div class="w-8 h-8 rounded-full flex items-center justify-center font-display font-semibold text-sm mb-4" style="background: var(--color-classic-accent); color: var(--color-classic-cta);">
              {i + 1}
            </div>
            <h3 class="text-base font-display font-medium mb-2 text-white">{t(p.title)}</h3>
            <p class="text-sm text-white/75 leading-relaxed">{t(p.text)}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>
)}
