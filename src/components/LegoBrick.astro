---
/**
 * Top-down view of a 2×2 LEGO brick with 4 studs.
 * Colour comes from the parent (CSS `color`). Pass a hex/var via the `color` prop
 * if you want to override locally; otherwise it inherits from the surrounding text.
 *
 * Usage:
 *   <LegoBrick />                              // inherits text colour
 *   <LegoBrick color="var(--color-lego-red)" />
 *   <LegoBrick size={28} color="#006cb3" />
 */
interface Props {
  size?: number;
  color?: string;
  class?: string;
}
const { size = 22, color, class: className } = Astro.props;
const style = color ? `color: ${color};` : '';
---
<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
  class:list={['shrink-0', className]}
  style={style}
>
  <!-- Brick body -->
  <rect x="1" y="1" width="22" height="22" rx="2.5" fill="currentColor" />
  <!-- 4 studs (2×2 grid) with subtle highlight rings -->
  <circle cx="7"  cy="7"  r="3.2" fill="currentColor" />
  <circle cx="7"  cy="7"  r="3.2" fill="none" stroke="white" stroke-opacity="0.4" stroke-width="1.2" />
  <circle cx="17" cy="7"  r="3.2" fill="currentColor" />
  <circle cx="17" cy="7"  r="3.2" fill="none" stroke="white" stroke-opacity="0.4" stroke-width="1.2" />
  <circle cx="7"  cy="17" r="3.2" fill="currentColor" />
  <circle cx="7"  cy="17" r="3.2" fill="none" stroke="white" stroke-opacity="0.4" stroke-width="1.2" />
  <circle cx="17" cy="17" r="3.2" fill="currentColor" />
  <circle cx="17" cy="17" r="3.2" fill="none" stroke="white" stroke-opacity="0.4" stroke-width="1.2" />
</svg>
