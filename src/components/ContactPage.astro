---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import ContactForm from './ContactForm.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const sent = Astro.url.searchParams.get('sent') === '1';
---
<section class="relative pt-16 md:pt-24 pb-8 overflow-hidden bg-white">
  <div class="absolute inset-0 -z-10 overflow-hidden pointer-events-none">
    <div class="absolute -top-24 -left-16 w-[24rem] h-[24rem] rounded-full opacity-[0.12] blur-3xl" style="background: var(--color-lego-blue);"></div>
    <div class="absolute -top-16 right-0 w-[18rem] h-[18rem] rounded-full opacity-[0.10] blur-3xl" style="background: var(--color-lego-yellow);"></div>
  </div>
  <div class="container-narrow relative">
    <span class="inline-block text-xs uppercase tracking-[0.2em] mb-4 font-semibold" style="color: var(--color-lego-blue);">
      {lang === 'cs' ? 'Spojte se s námi' : lang === 'en' ? 'Get in touch' : 'Kontakt aufnehmen'}
    </span>
    <h1 class="text-4xl md:text-5xl lg:text-6xl font-medium mb-5 leading-[1.1]">{t('contact.title')}</h1>
    <p class="text-lg md:text-xl text-[var(--color-ink-soft)] max-w-2xl leading-relaxed">{t('contact.lead')}</p>
  </div>
</section>

<section class="py-12 md:py-16">
  <div class="container-wide grid lg:grid-cols-12 gap-10">
    <div class="lg:col-span-7">
      {sent ? (
        <div class="bg-[var(--color-cta)] text-white rounded-2xl p-8 md:p-10">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="mb-4">
            <circle cx="12" cy="12" r="10"/><path d="M9 12l2 2 4-4"/>
          </svg>
          <h2 class="text-2xl font-medium mb-2 text-white">{t('contact.form.success')}</h2>
          <p class="text-white/80">{lang === 'cs' ? 'Vaše poptávka dorazila. Odpovíme do 24 hodin.' : lang === 'en' ? 'Your inquiry has been received. We will reply within 24 hours.' : 'Ihre Anfrage ist eingegangen. Wir antworten innerhalb von 24 Stunden.'}</p>
        </div>
      ) : (
        <div class="bg-white border border-[var(--color-line)] rounded-2xl p-7 md:p-10">
          <ContactForm />
        </div>
      )}
    </div>

    <aside class="lg:col-span-5 space-y-6">
      <div class="bg-white border border-[var(--color-line)] rounded-2xl p-7">
        <h3 class="font-display text-xl font-medium mb-4">{t('footer.contact')}</h3>
        <ul class="space-y-3 text-sm">
          <li class="flex items-center gap-3">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-[var(--color-cta)]"><path d="M4 4h16c1 0 2 1 2 2v12c0 1-1 2-2 2H4c-1 0-2-1-2-2V6c0-1 1-2 2-2z"/><path d="M22 6l-10 7L2 6"/></svg>
            <a href="mailto:info@estom.cz" class="hover:text-[var(--color-cta)]">info@estom.cz</a>
          </li>
          <li class="flex items-center gap-3">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-[var(--color-cta)]"><path d="M22 16v3a2 2 0 0 1-2 2A19 19 0 0 1 3 5a2 2 0 0 1 2-2h3a2 2 0 0 1 2 1.7l1 4-2 2a16 16 0 0 0 6 6l2-2 4 1A2 2 0 0 1 22 16z"/></svg>
            <a href="tel:+420777925594" class="hover:text-[var(--color-cta)]">+420 777 925 594</a>
          </li>
          <li class="flex items-start gap-3">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-[var(--color-cta)] mt-0.5"><path d="M12 2a8 8 0 0 0-8 8c0 5.5 8 12 8 12s8-6.5 8-12a8 8 0 0 0-8-8zm0 11a3 3 0 1 1 0-6 3 3 0 0 1 0 6z"/></svg>
            <span>I. Olbrachta 910/34<br/>České Budějovice</span>
          </li>
        </ul>
      </div>

      <div class="aspect-[4/3] rounded-2xl overflow-hidden bg-[var(--color-line)]">
        <iframe
          src="https://maps.google.com/maps?q=I.+Olbrachta+910%2F34%2C+%C4%8Cesk%C3%A9+Bud%C4%9Bjovice&output=embed&hl=cs&z=16&iwloc=B"
          class="w-full h-full border-0"
          loading="lazy"
          title="Mapa apartmánu — I. Olbrachta 910/34, České Budějovice"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </aside>
  </div>
</section>
